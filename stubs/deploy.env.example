# Copy to deploy/deploy.env (gitignored) and fill in your production server details.
#
# One-time server setup (SSH):
#   mkdir -p ~/your-app && cd ~/your-app
#   cp .env.example .env   # edit APP_ENV=production, APP_DEBUG=false, DB_*
#   php artisan key:generate
#   php artisan storage:link
#   php artisan migrate --force
#
# First deploy:
#   prod-deploy build
#   prod-deploy vendor:zip-push    # upload vendor.zip, then SSH extract (see below)
#   prod-deploy push               # app files only (no vendor)
#
# Vendor updates (separate from app push):
#   prod-deploy vendor:push        # only changed vendor files
#   prod-deploy vendor:zip-push    # full vendor as zip (first time / bulk)
#   SSH after zip:  cd ~/your-app && unzip -o vendor.zip && rm vendor.zip
#
# push never uploads vendor — it warns if vendor/ changed.
# Hotfix single file/folder:  prod-deploy push:target -- app/Livewire/Foo.php
# cPanel: point document root to PROD_REMOTE_PATH/public

PROD_SSH_HOST=yourdomain.com
PROD_SSH_USER=cpanel_username
PROD_SSH_PORT=22
PROD_REMOTE_PATH=/home/cpanel_username/your-app

# Auth (use key OR password — same credentials as FileZilla/SSH terminal)
# PROD_SSH_PASSWORD=
# PROD_SSH_KEY=C:/Users/You/.ssh/id_rsa
