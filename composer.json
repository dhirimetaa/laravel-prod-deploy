{
    "name": "dhirimetaa/laravel-prod-deploy",
    "description": "Build prodfiles and deploy Laravel apps to shared hosting via SFTP (Windows-friendly)",
    "type": "composer-plugin",
    "license": "MIT",
    "version": "1.2.0",
    "homepage": "https://github.com/dhirimetaa/laravel-prod-deploy",
    "support": {
        "issues": "https://github.com/dhirimetaa/laravel-prod-deploy/issues",
        "source": "https://github.com/dhirimetaa/laravel-prod-deploy"
    },
    "authors": [
        {
            "name": "dhirimetaa",
            "homepage": "https://github.com/dhirimetaa"
        }
    ],
    "require": {
        "php": "^8.2",
        "composer-plugin-api": "^2.2",
        "phpseclib/phpseclib": "^3.0"
    },
    "require-dev": {
        "composer/composer": "^2.7",
        "phpunit/phpunit": "^11.0"
    },
    "bin": [
        "bin/prod-deploy"
    ],
    "autoload": {
        "psr-4": {
            "Dhirimetaa\\ProdDeploy\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dhirimetaa\\ProdDeploy\\Tests\\": "tests/"
        }
    },
    "extra": {
        "class": "Dhirimetaa\\ProdDeploy\\Composer\\Plugin"
    },
    "scripts": {
        "test": "phpunit"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
